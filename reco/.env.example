# narci-reco 配置模板 — 复制到 .env 后填实值

# AWS 凭证 (从 echo-air 同套路:aws-cli profile + Secret Manager 处理)
# 不在这里硬编码 access key,用 named profile
AWS_PROFILE=narci-reco
AWS_REGION_JP=ap-northeast-1
AWS_REGION_SG=ap-southeast-1

# EC2 实例 ID — 你在 AWS Console 抄过来
NARCI_JP_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
NARCI_SG_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# Recorder 在 instance 内的部署路径 (deploy-时跟 docker compose 文件同目录)
NARCI_DEPLOY_PATH=/home/ubuntu/narci

# Health probe 用的本地端口 (instance 内 curl localhost:PORT/health)
NARCI_JP_HEALTH_PORTS=8079,8081,8082
NARCI_SG_HEALTH_PORTS=8080

# tailscale (future,donor 接管时填)
# NARCI_DONOR_TAILSCALE_HOST=narci-donor
